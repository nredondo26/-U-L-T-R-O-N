{
  "name": "ultron",
  "version": "5.0.0",
  "private": true,
  "description": "ULTRON - Neural Intelligence Platform (multi-agent CLI)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun run src/index.ts",
    "web": "bun run src/index.ts --web",
    "build": "bun build src/index.ts --outdir dist --target node",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:jest": "bun jest",
    "test:jest:watch": "bun jest --watch",
    "test:jest:coverage": "bun jest --coverage",
    "test:mocha": "bun mocha",
    "test:mocha:watch": "bun mocha --watch",
    "test:mocha:coverage": "bun nyc mocha",
    "test:all": "bun test && bun jest && bun mocha",
    "compile": "bun build src/index.ts --compile --outfile dist/ultron.exe --target bun-windows-x64 && node scripts/set-icon.js && node scripts/copy-public.cjs",
    "compile:linux": "bun build src/index.ts --compile --outfile dist/ultron --target bun-linux-x64",
    "compile:node": "bun build src/index.ts --compile --outfile dist/ultron.exe --target node-windows-x64",
    "desktop": "powershell -ExecutionPolicy Bypass -File electron/ultron-desktop.ps1",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "prepublishOnly": "bun run typecheck && bun run test && bun run build",
    "ci": "bun run typecheck && bun run test"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "mammoth": "^1.12.0",
    "openai": "^5.6.0",
    "pdf-parse": "^2.4.5",
    "xlsx": "^0.18.5",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "@types/pdf-parse": "^1.1.5",
    "bun-types": "1.3.14",
    "rcedit": "^5.0.2",
    "typescript": "^5.8.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/ultron.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/ultron/issues"
  },
  "keywords": ["ai", "cli", "agents", "llm", "automation"],
  "author": "ULTRON Team"
}
