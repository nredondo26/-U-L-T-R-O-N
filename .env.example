# ULTRON — API Keys Configuration
# Set at least one provider key for the assistant to work.

# AlibabaCloud Model Studio (DashScope) — RECOMMENDED
# Get your key at: https://bailian.console.aliyun.com
DASHSCOPE_API_KEY=sk-xxxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# DeepSeek API
# Get your key at: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxx

# NVIDIA NIM (free models available)
# Get your key at: https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxx

# OpenRouter (multi-provider)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxx

# Google Gemini (free tier)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza-xxxx

# Groq (fast inference, free tier)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxx

# Mistral AI
# Get your key at: https://console.mistral.ai/
MISTRAL_API_KEY=xxxx

# Cohere
# Get your key at: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=xxxx

# Local Models (Ollama)
# Install: https://ollama.com
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Local Models (LM Studio)
# Install: https://lmstudio.ai
# LM_STUDIO_BASE_URL=http://localhost:1234

# Optional: Web dashboard authentication
# Set a secret key to protect the web dashboard
ULTRON_API_KEY=your-secret-api-key-here

# Optional: Per-agent model overrides
# ULTRON_MODEL_EDITOR=qwen-coder-plus
# ULTRON_MODEL_BASHER=deepseek-chat
# ULTRON_MODEL_RESEARCHER=meta/llama-3.1-8b-instruct

# Optional: Logging
JARVIS_LOG_LEVEL=info  # debug | info | warn | error
