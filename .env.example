# DeepSeek (recomendado como primario)
DEEPSEEK_API_KEY=sk-your-deepseek-key

# NVIDIA NIM (fallback)
NVIDIA_API_KEY=nvapi-your-nvidia-key

# OpenRouter (opcional, acceso a cientos de modelos)
OPENROUTER_API_KEY=sk-or-v1-your-key

# Configuracion de vault (memoria persistente)
VAULT_DIR=./vault

# Directorio del proyecto a trabajar (default: dir actual)
PROJECT_DIR=.
